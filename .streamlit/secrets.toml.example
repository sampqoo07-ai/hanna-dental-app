# 複製成 secrets.toml 並填入實際值
# Streamlit Cloud 部署時改用 Settings → Secrets 介面貼上

app_password = "改成你們的共用密碼"

[supabase]
url = "https://xxxxx.supabase.co"
anon_key = "從 Supabase Project Settings → API 複製"
service_key = "service_role key（只在伺服器端用，不要外洩）"
bucket = "dental-uploads"

[smtp]
# 寄居家牙醫申請信給公會時用
# Gmail：到 Google 帳戶 → 安全性 → 兩步驟驗證 → 應用程式密碼 生成 16 碼
sender = "your-clinic-gmail@gmail.com"
app_password = "16 碼 Gmail 應用程式密碼（去掉空白）"
